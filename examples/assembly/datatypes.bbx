%asm
;3
;
%data
    byte $byte, 10 
    word $word, 300
    dword $dword, 70000
    qword $qword, 5000000000
    str $str, "Hello, World!"
%main
    loadbyte $byte, R01 ;6
    loadword $word, R02 ;6
    loaddword $dword, R03 ;6
    loadqword $qword, R04 ;6
    loadstr $str, R05 ;6
    printstr R05 ;2
    newline
    printreg R01 ;2
    newline ;3
    printreg R02 ;2
    newline ;3
    printreg R03 ;2
    newline ;3
    printreg R04 ;2
    newline  ;1
    halt ok