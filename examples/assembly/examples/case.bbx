%asm
;tests case sensitivity for labels and macros
%macro lowercase
    write STDOUT "lowercase"
    newline
    call lowercase
%endmacro

%macro Lowercase
    write STDOUT "Lowercase"
    newline
    call Lowercase
%endmacro

%main
    %lowercase
    %Lowercase
    halt ok
    lowercase:
        write STDOUT "lowercase label"
        newline
        ret
    Lowercase:
        write STDOUT "Lowercase label"
        newline
        ret
    halt ok