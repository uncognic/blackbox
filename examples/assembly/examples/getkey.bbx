.asm
; demonstrates GETKEY non-blocking instruction
.data
    prompt "Press a key (or wait briefly)..."
    no_key "No key pressed"
    got "Got key: "

.main
    loadstr $prompt, R1
    printstr R1
    newline


wait:
    getkey R0
    mov R1, R0
    inc R1
    MOV R2, 0
    cmp R1, R2
    jne got
    sleep 100
    jmp wait

    loadstr $no_key, R2
    printstr R2
    newline
    HLT ok

got:
    loadstr $got, R2
    printstr R2
    printreg R0
    newline
    HLT ok