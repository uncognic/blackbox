%asm
; Shift operations demo
%main
    ; SHL: 1 << 3 = 8
    MOVI R00, 1
    SHL R00, 3
    PRINTREG R00
    NEWLINE

    ; SHR: 16 >> 2 = 4
    MOVI R01, 16
    SHR R01, 2
    PRINTREG R01
    NEWLINE

    ; SHR on negative: -8 >> 1 = -4
    MOVI R02, -8
    SHR R02, 1
    PRINTREG R02
    NEWLINE

    ; large shift amounts are encoded as 64-bit immediates
    MOVI R03, 1
    SHL R03, 64
    PRINTREG R03
    NEWLINE

    MOVI R04, -1
    SHR R04, 100
    PRINTREG R04
    NEWLINE

    HALT OK
