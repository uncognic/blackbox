.asm
.data
    OUT_MSG "stdout message"
    ERR_MSG "stderr message"
.main
    LOADSTR $OUT_MSG, R1 ; stdout message
    PRINTSTR R1
    NEWLINE

    LOADSTR $ERR_MSG, R1 ; stderr message
    EPRINTSTR R1
    NEWLINE

    MOV R2, 123
    PRINTREG R2 ; print 123
    MOV R3, 10
    PRINTCHAR R3 ; print newline (ascii 10)

    EPRINTREG R2 ; print 123 to stderr
    EPRINTCHAR R3 ; print newline to stderr

    HLT OK
