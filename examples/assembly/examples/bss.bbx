%asm
%bss
    counter
    something

%macro inc_counter
    MOV R00, [counter]
    INC R00
    MOV [counter], R00
%endmacro

%entry
    MOV R0, 67
    MOV [something], R00

    %inc_counter
    %inc_counter
    %inc_counter

    MOV R01, [counter]
    MOV R02, [something]

    PRINTREG R01
    PRINTREG R02

    HALT