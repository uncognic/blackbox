.asm
.bss
    counter
    something

.macro inc_counter
    INC [counter]
.endmacro

.entry
    MOV [something], 67

    %inc_counter
    %inc_counter
    %inc_counter

    MOV R1, [counter]

    SUB [something], 1
    ADD [something], 1

    MOV R2, [something]

    PRINTREG R1
    PRINTREG R2

    HLT