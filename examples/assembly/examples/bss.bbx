%asm
%bss
    counter
    something

%macro inc_counter
    INC [counter]
%endmacro

%entry
    MOV [something], 67

    %inc_counter
    %inc_counter
    %inc_counter

    MOV R01, [counter]

    SUB [something], 1
    ADD [something], 1

    MOV R02, [something]

    PRINTREG R01
    PRINTREG R02

    HALT