%asm
%main
alloc 100
;store 42 at stack index 10
MOV R00, 42
store R00, 10
;load it back and print
load R01, 10
printreg R01
newline

;store using a register as the index
MOV R02, 123 ;value to store
MOV R10, 11 ;index in R10
store R02, R10 ;store R02 at stack index 11
load R03, R10 ;load back into R03
printreg R03
newline

halt ok
