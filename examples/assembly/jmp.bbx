;unconditional jump
;should print 1, 2, 3 in an infinite loop
%asm
%main
    .label1:
    movi r01, 1
    printreg r01
    newline
    jmp label2

    .label2:
    movi r02, 2
    printreg r02
    newline
    jmp label3

    .label3:
    movi r03, 3
    printreg r03
    newline
    jmp label1
    halt ok