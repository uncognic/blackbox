%asm
;FizzBuzz for the Blackbox assembly language.
%main
    movi r00, 1
    movi r01, 101
    movi r10, 0
.loop:
    mov r02, r00
    movi r03, 15
    mod r02, r03
    cmp r02, r10
    je fizzbuzz
    mov r02, r00
    movi r15, 3
    mod r02, r15
    cmp r02, r10
    je fizz
    mov r02, r00
    movi r16, 5
    mod r02, r16
    cmp r02, r10
    je buzz
    printreg r00
    newline
    jmp next
.fizzbuzz:
    write stdout "FizzBuzz"
    newline
    jmp next
.fizz:
    write stdout "Fizz"
    newline
    jmp next
.buzz:
    write stdout "Buzz"
    newline
.next:
    inc r00
    cmp r00, r01
    jne loop
    halt ok