VAR INITIAL_VALUE = 10
VAR OTHER_VALUE = INITIAL_VALUE + 5

WRITE "Initial value: "
PRINT INITIAL_VALUE

WRITE "Other value: "
PRINT OTHER_VALUE

VAR INITIAL_STRING = "Hello"
WRITE "Initial string: "
PRINT INITIAL_STRING

INITIAL_STRING = "World"
WRITE "Updated string: "
PRINT INITIAL_STRING

HALT OK