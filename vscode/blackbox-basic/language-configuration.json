{
  "comments": {
    "lineComment": "//"
  },

  "brackets": [
    ["(", ")"]
  ],

  "autoClosingPairs": [
    { "open": "\"", "close": "\"" },
    { "open": "(", "close": ")" }
  ],

  "surroundingPairs": [
    ["\"", "\""],
    ["(", ")"]
  ],

  "indentationRules": {
    "increaseIndentPattern": ".*\\b(FUNC|IF|FOR)\\b.*:$",
    "decreaseIndentPattern": "^\\s*\\b(ENDFUNC|ENDIF|NEXT)\\b"
  }
}