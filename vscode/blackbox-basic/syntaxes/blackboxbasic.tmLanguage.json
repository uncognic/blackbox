{
	"scopeName": "source.blackboxbasic",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#operators"
		},
		{
			"include": "#functions"
		},
		{
			"include": "#function-calls"
		},
		{
			"include": "#variables"
		},
		{
			"include": "#function-params"
		}
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.line.double-slash.blackboxbasic",
					"match": "//.*$"
				}
			]
		},
		"strings": {
			"patterns": [
				{
					"name": "string.quoted.double.blackboxbasic",
					"begin": "\"",
					"end": "\""
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.blackboxbasic",
					"match": "(?:\\b(FUNC|ENDFUNC|RETURN|IF|ELSE|ELSE IF|ENDIF|WHILE|ENDWHILE|FOR|NEXT|CALL|TO|STEP|BREAK|CONTINUE|HALT|LABEL|GOTO|INC|DEC|INPUT|RANDOM|SLEEP|EXEC|GETKEY|GETARGC|GETARG|GETENV|FOPEN|FCLOSE|FREAD|FWRITE|FSEEK|FPRINT|ASM|ENDASM)\\b|(?<!\\w)@ENTRY(?!\\w))"
				},
				{
					"name": "storage.type.blackboxbasic",
					"match": "\\b(VAR|CONST|STR)\\b"
				},
				{
					"name": "support.function.blackboxbasic",
					"match": "\\b(PRINT|WRITE|EPRINT|EWRITE)\\b"
				}
			]
		},
		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.blackboxbasic",
					"match": "\\b\\d+\\b"
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.blackboxbasic",
					"match": "(\\+|\\-|\\*|\\/|%|==|!=|<=|>=|<|>|=|&|\\||\\^|~|<<|>>)"
				}
			]
		},
		"functions": {
			"patterns": [
				{
					"name": "entity.name.function.definition.blackboxbasic",
					"match": "(?<=\\bFUNC\\s)\\w+"
				}
			]
		},
		"function-params": {
			"patterns": [
				{
					"name": "variable.parameter.blackboxbasic",
					"match": "(?<=\\b(VAR|STR)\\s)\\w+"
				}
			]
		},
		"function-calls": {
			"patterns": [
				{
					"name": "entity.name.function.call.blackboxbasic",
					"match": "\\b\\w+(?=\\()"
				}
			]
		},
		"variables": {
			"patterns": [
				{
					"name": "variable.declaration.blackboxbasic",
					"match": "(?<=\\bVAR\\s)\\w+"
				}
			]
		}
	}
}